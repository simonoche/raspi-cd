# Copy this file to /etc/raspicd/agent.env and fill in your values.
# Protect it: chmod 600 /etc/raspicd/agent.env

RASPICD_SERVER=https://your-server.example.com
RASPICD_AGENT_ID=raspi-living-room
RASPICD_AGENT_SECRET=change-me-to-a-strong-random-secret
RASPICD_POLL_INTERVAL=30s

# Directory containing named scripts (.sh files) — default: /etc/raspicd/scripts
# RASPICD_SCRIPTS_DIR=/etc/raspicd/scripts

# Optional
# RASPICD_DEBUG=true
