# Copy this file to /etc/raspicd/agent.env and fill in your values.
# Protect it: chmod 600 /etc/raspicd/agent.env

RASPIDEPLOY_SERVER=https://your-server.example.com
RASPIDEPLOY_AGENT_ID=raspi-living-room
RASPIDEPLOY_AGENT_SECRET=change-me-to-a-strong-random-secret
RASPIDEPLOY_POLL_INTERVAL=30s

# Directory containing named scripts (.sh files) — default: /etc/raspicd/scripts
# RASPIDEPLOY_SCRIPTS_DIR=/etc/raspicd/scripts

# Optional
# RASPIDEPLOY_DEBUG=true
